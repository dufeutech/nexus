# Production compose configuration. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored. The Envoy upstreams (ZITADEL JWKS + backend pools) are NOT
# here — they are edited directly in ./envoy/envoy.yaml.

# --- Images -----------------------------------------------------------------
# Registry namespaces for the first-party images. Leave the defaults to build
# locally (the compose `build:` stanzas); set to your registry to pull.
IDENTITY_REPO=identity
ROUTING_REPO=routing
IMAGE_TAG=0.1.0
# Pin Envoy to a concrete patch version in production.
ENVOY_VERSION=v1.34-latest

# --- Edge -------------------------------------------------------------------
EDGE_PORT=10000

# --- EXTERNAL MongoDB (identity store + change feed) ------------------------
# Replica set REQUIRED (change streams). Embed credentials in the URI if needed.
MONGO_URL=mongodb://mongo-0,mongo-1,mongo-2/?replicaSet=rs0
MONGO_DB=identity
MONGO_COLLECTION=profiles
CACHE_TTL_SECONDS=43200
READINESS_DELAY_SECONDS=0

# --- EXTERNAL PostgreSQL (authoritative routing store) ----------------------
# DIRECT/session connection — used by the LISTEN/NOTIFY invalidation feed and the
# control plane. MUST NOT be a transaction-mode pooler (PgBouncer/RDS-Proxy txn
# mode), which silently swallows LISTEN. See deploy/README "External Postgres".
ROUTING_PG_URL=postgres://user:pass@postgres.example.com:5432/routing
# OPTIONAL: a separate POOLED endpoint for the tenant-router's cache-miss reads
# (e.g. a transaction-mode PgBouncer). Leave empty to read over the direct URL.
ROUTING_PG_READ_URL=
ROUTING_CACHE_CAPACITY=200000
ROUTING_CACHE_TTL=600

# --- EXTERNAL Redis (OPTIONAL routing L2) -----------------------------------
# Leave empty for L1-only (still correct). e.g. redis://redis.example.com:6379
REDIS_URL=
ROUTING_L2_TTL=600

# --- EXTERNAL ZITADEL (the IdP) ---------------------------------------------
# Internal endpoint the workers dial; ZITADEL_HOST is the issuer authority.
ZITADEL_INTERNAL_URL=http://zitadel.example.com:8080
ZITADEL_HOST=auth.example.com
# A URL ZITADEL can reach to deliver Actions v2 webhooks to the sync-worker.
WEBHOOK_SELF_URL=http://sync-worker.internal:8080/webhook

# --- Logging ----------------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=info
RUST_LOG=info
RECONCILE_INTERVAL=600
RECONCILE_PAGE_LIMIT=1000
