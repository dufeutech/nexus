# Production compose configuration. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored. The Envoy upstreams (OIDC provider JWKS + backend pools) are NOT
# here — they are edited directly in ./envoy/envoy.yaml.

# --- Images -----------------------------------------------------------------
# Registry namespaces for the first-party images. Leave the defaults to build
# locally (the compose `build:` stanzas); set to your registry to pull.
IDENTITY_REPO=identity
ROUTING_REPO=routing
IMAGE_TAG=0.1.0
# Pin Envoy to a concrete patch version + digest in production. The digest is the
# immutable identity `v1.34.14` resolved to on 2026-07-06; the tag is kept for
# human readability. Re-resolve with:
#   docker buildx imagetools inspect envoyproxy/envoy:v1.34.14 | grep Digest
ENVOY_VERSION=v1.34.14@sha256:cfc0678bc03cca19cbb031688acb31d510bff501ff97e163026a375fe0515d69

# --- Edge -------------------------------------------------------------------
EDGE_PORT=10000
# N6 edge-rooted tracing: head-sampling rate in whole percent (0-100);
# 100 = trace every request. Unsampled requests still carry a not-sampled
# W3C traceparent to the backend (the head decision propagates). Traces
# export OTLP/gRPC to the `otel_collector` cluster in ./envoy/envoy.yaml —
# point that at YOUR OTel Collector (this stack bundles no monitoring).
# Fail-open: an unreachable collector never affects request handling.
TRACE_SAMPLING_PCT=100

# --- EXTERNAL PostgreSQL (identity store + change feed) ---------------------
# DIRECT/session connection — used by the sidecar's LISTEN/NOTIFY change feed
# (channel `identity_changes`) and the writers. MUST NOT be a transaction-mode
# pooler (PgBouncer/RDS-Proxy txn mode), which silently swallows LISTEN. The app
# creates the `identity` schema inside whatever database the URL points at.
# ENCRYPTION IN TRANSIT: production URLs MUST carry `?sslmode=verify-full` (encrypt
# + verify the server cert against a CA) so DB credentials and profile/PII rows are
# not exposed on the wire. `require` only encrypts (no MITM protection); `disable`
# is dev-only against a trusted-loopback DB.
PROFILE_PG_URL=postgres://user:pass@host:5432/identitydb?sslmode=verify-full
CACHE_TTL_SECONDS=43200
READINESS_DELAY_SECONDS=0

# --- EXTERNAL PostgreSQL (authoritative routing store) ----------------------
# DIRECT/session connection — used by the LISTEN/NOTIFY invalidation feed and the
# control plane. MUST NOT be a transaction-mode pooler (PgBouncer/RDS-Proxy txn
# mode), which silently swallows LISTEN. See deploy/README "External Postgres".
# ENCRYPTION IN TRANSIT: production URLs MUST carry `?sslmode=verify-full` (see the
# PROFILE_PG_URL note above).
ROUTING_PG_URL=postgres://user:pass@postgres.example.com:5432/routing?sslmode=verify-full
# OPTIONAL: a separate POOLED endpoint for the tenant-router's cache-miss reads
# (e.g. a transaction-mode PgBouncer). Leave empty to read over the direct URL.
ROUTING_PG_READ_URL=
ROUTING_CACHE_CAPACITY=200000
ROUTING_CACHE_TTL=600
# READ-ONLY routing connection for the identity plane's membership-sync worker: it
# LISTENs on `routing_membership_changes` + SELECTs `routing.memberships` to project
# memberships into the identity Profile (what makes the sidecar's acting-workspace
# scope resolve). MUST be a DIRECT/session connection (a txn-mode pooler swallows
# LISTEN). Grant least privilege — SELECT + LISTEN, no write. A SEPARATE credential
# from ROUTING_PG_URL (read-only) is strongly preferred.
ROUTING_PG_RO_URL=postgres://ro_user:pass@postgres.example.com:5432/routing?sslmode=verify-full
# Membership backstop reconcile interval (seconds): re-derives every subject's
# memberships to heal a missed NOTIFY and backfill on first run.
MEMBERSHIP_BACKSTOP_INTERVAL=600
# Backend-pool allow-list (RFC C15) the control plane validates `target_pool`
# against. JSON array; leave empty for the built-in default
# ["application","api","checkout","assets"]. This MUST match the `pool_*` clusters
# in ./envoy/envoy.yaml — to add a pool, list it here AND add its cluster + route
# there (no recompile). See ../../docs/backend-pools.md.
# ROUTING_POOLS=["application","api","checkout","assets","media"]

# --- Control-plane admin auth (RFC C16) -------------------------------------
# The control plane's data endpoints (/tenants, /domains, /domains/declare,
# /domains/{d}/verify, auth-routes) mutate the authoritative routing store and
# REQUIRE this bearer token (`Authorization: Bearer <token>`). Fail-closed: the
# container refuses to start unless this is set OR CONTROL_AUTH_DISABLED=true.
# Generate a strong random value, e.g.  openssl rand -hex 32
CONTROL_AUTH_TOKEN=
# Set to true ONLY on a trusted network / local dev to run WITHOUT auth.
CONTROL_AUTH_DISABLED=

# --- Nexus-native authorization authoring (authz-admin) ---------------------
# The authz-admin surface authors roles/entitlements/suspension into the identity
# store (nexus-native-authorization). The OIDC provider is NEVER an authorization
# source — it only proves identity. The authoring endpoints REQUIRE this bearer
# token (`Authorization: Bearer <token>`). Fail-closed: the container refuses to
# start unless this is set OR IDENTITY_ADMIN_AUTH_DISABLED=true. Generate a strong
# random value, e.g.  openssl rand -hex 32
IDENTITY_ADMIN_TOKEN=
# Set to true ONLY on a trusted network / local dev to run WITHOUT auth.
IDENTITY_ADMIN_AUTH_DISABLED=
# Bootstrap the first administrator (nexus-native-authorization R4): the subject
# `sub` granted AUTHZ_ADMIN_ROLE at startup IFF no administrator exists yet
# (idempotent break-glass). Leave AUTHZ_BOOTSTRAP_ADMIN_SUB empty to skip the seed
# and author the first grants directly via the admin API. Rotate/disable the
# bootstrap after a real admin is authored.
AUTHZ_ADMIN_ROLE=admin
AUTHZ_BOOTSTRAP_ADMIN_SUB=

# --- EXTERNAL Redis (OPTIONAL routing L2) -----------------------------------
# Leave empty for L1-only (still correct). e.g. redis://redis.example.com:6379
REDIS_URL=
ROUTING_L2_TTL=600

# --- Logging ----------------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=info
RUST_LOG=info
