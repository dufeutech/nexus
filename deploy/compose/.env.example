# Production compose configuration. Copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored. The Envoy upstreams (ZITADEL JWKS + backend pools) are NOT
# here — they are edited directly in ./envoy/envoy.yaml.

# --- Images -----------------------------------------------------------------
# Registry namespaces for the first-party images. Leave the defaults to build
# locally (the compose `build:` stanzas); set to your registry to pull.
IDENTITY_REPO=identity
ROUTING_REPO=routing
IMAGE_TAG=0.1.0
# Pin Envoy to a concrete patch version in production.
ENVOY_VERSION=v1.34-latest

# --- Edge -------------------------------------------------------------------
EDGE_PORT=10000

# --- EXTERNAL PostgreSQL (identity store + change feed) ---------------------
# DIRECT/session connection — used by the sidecar's LISTEN/NOTIFY change feed
# (channel `identity_changes`) and the writers. MUST NOT be a transaction-mode
# pooler (PgBouncer/RDS-Proxy txn mode), which silently swallows LISTEN. The app
# creates the `identity` schema inside whatever database the URL points at.
# ENCRYPTION IN TRANSIT: production URLs MUST carry `?sslmode=verify-full` (encrypt
# + verify the server cert against a CA) so DB credentials and profile/PII rows are
# not exposed on the wire. `require` only encrypts (no MITM protection); `disable`
# is dev-only against a trusted-loopback DB.
PROFILE_PG_URL=postgres://user:pass@host:5432/identitydb?sslmode=verify-full
CACHE_TTL_SECONDS=43200
READINESS_DELAY_SECONDS=0

# --- EXTERNAL PostgreSQL (authoritative routing store) ----------------------
# DIRECT/session connection — used by the LISTEN/NOTIFY invalidation feed and the
# control plane. MUST NOT be a transaction-mode pooler (PgBouncer/RDS-Proxy txn
# mode), which silently swallows LISTEN. See deploy/README "External Postgres".
# ENCRYPTION IN TRANSIT: production URLs MUST carry `?sslmode=verify-full` (see the
# PROFILE_PG_URL note above).
ROUTING_PG_URL=postgres://user:pass@postgres.example.com:5432/routing?sslmode=verify-full
# OPTIONAL: a separate POOLED endpoint for the tenant-router's cache-miss reads
# (e.g. a transaction-mode PgBouncer). Leave empty to read over the direct URL.
ROUTING_PG_READ_URL=
ROUTING_CACHE_CAPACITY=200000
ROUTING_CACHE_TTL=600
# Backend-pool allow-list (RFC C15) the control plane validates `target_pool`
# against. JSON array; leave empty for the built-in default
# ["application","api","checkout","assets"]. This MUST match the `pool_*` clusters
# in ./envoy/envoy.yaml — to add a pool, list it here AND add its cluster + route
# there (no recompile). See ../../docs/backend-pools.md.
# ROUTING_POOLS=["application","api","checkout","assets","media"]

# --- Control-plane admin auth (RFC C16) -------------------------------------
# The control plane's data endpoints (/tenants, /domains, /domains/declare,
# /domains/{d}/verify, auth-routes) mutate the authoritative routing store and
# REQUIRE this bearer token (`Authorization: Bearer <token>`). Fail-closed: the
# container refuses to start unless this is set OR CONTROL_AUTH_DISABLED=true.
# Generate a strong random value, e.g.  openssl rand -hex 32
CONTROL_AUTH_TOKEN=
# Set to true ONLY on a trusted network / local dev to run WITHOUT auth.
CONTROL_AUTH_DISABLED=

# --- EXTERNAL Redis (OPTIONAL routing L2) -----------------------------------
# Leave empty for L1-only (still correct). e.g. redis://redis.example.com:6379
REDIS_URL=
ROUTING_L2_TTL=600

# --- EXTERNAL ZITADEL (the IdP) ---------------------------------------------
# Internal endpoint the workers dial; ZITADEL_HOST is the issuer authority.
ZITADEL_INTERNAL_URL=http://zitadel.example.com:8080
ZITADEL_HOST=auth.example.com
# A URL ZITADEL can reach to deliver Actions v2 webhooks to the sync-worker.
WEBHOOK_SELF_URL=http://sync-worker.internal:8080/webhook

# --- Logging ----------------------------------------------------------------
LOG_FORMAT=json
LOG_LEVEL=info
RUST_LOG=info
RECONCILE_INTERVAL=600
RECONCILE_PAGE_LIMIT=1000
