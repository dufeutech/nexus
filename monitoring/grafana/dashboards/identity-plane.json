{
  "uid": "identity-plane",
  "title": "Identity Plane (RFC C12 / §10)",
  "tags": [
    "identity-plane"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Sidecar ready",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "warming",
                  "color": "red"
                },
                "1": {
                  "text": "ready",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sidecar_ready)"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Time to warm (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sidecar_time_to_warm_seconds)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Resident Profiles",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sidecar_cache_entries)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Watcher lag (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(sidecar_kv_last_apply_timestamp_seconds)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "ext_proc enrichment latency",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(rate(sidecar_ext_proc_duration_seconds[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(sidecar_ext_proc_duration_seconds[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(sidecar_ext_proc_duration_seconds[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "ext_proc requests/s by result",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(sidecar_ext_proc_requests_total[1m]))",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cache hit / miss per second",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(sidecar_cache_hits_total[1m])",
          "legendFormat": "hits"
        },
        {
          "refId": "B",
          "expr": "rate(sidecar_cache_misses_total[1m])",
          "legendFormat": "misses"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "KV updates/s applied by sidecar",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (op) (rate(sidecar_kv_updates_total[5m]))",
          "legendFormat": "{{op}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Sync-worker events/s by result",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(sync_events_total[5m]))",
          "legendFormat": "{{result}}"
        },
        {
          "refId": "B",
          "expr": "rate(sync_signature_failures_total[5m])",
          "legendFormat": "sig failures"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Reconcile drift (last pass)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "expr": "reconcile_last_drift_upserts",
          "legendFormat": "drift upserts"
        },
        {
          "refId": "B",
          "expr": "reconcile_last_orphan_deletes",
          "legendFormat": "orphan deletes"
        },
        {
          "refId": "C",
          "expr": "reconcile_scanned",
          "legendFormat": "scanned"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Envoy edge responses/s by class",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (envoy_response_code_class) (rate(envoy_http_downstream_rq_xx[5m]))",
          "legendFormat": "{{envoy_response_code_class}}xx"
        }
      ]
    }
  ]
}